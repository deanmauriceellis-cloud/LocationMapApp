# LocationMapApp cache-proxy environment — TEMPLATE
#
# Copy this file to `cache-proxy/.env` and fill in real values.
# `cache-proxy/.env` is gitignored; this file is committed.
#
# Per OMEN-002, no real credential values may appear in this template.

# PostgreSQL — local Salem/LocationMapApp database
DATABASE_URL=postgres://USER:PASSWORD@localhost/locationmapapp

# JWT signing secret — leave blank to use a random per-boot secret
# (sessions won't survive restarts). Set to a long stable string for persistence.
# Generate one with: openssl rand -hex 32
JWT_SECRET=

# OpenSky Network OAuth2 — register at https://opensky-network.org/
# Leaving either blank falls back to anonymous mode (heavily rate-limited).
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Admin Basic Auth — gates /admin/* and /cache/clear (Phase 9P.3)
# Both must be set or admin routes hard-fail at startup.
ADMIN_USER=
ADMIN_PASS=

# Chat — V2 social feature, disabled by default. Flip to `true` after the
# chat schema has been provisioned on the connected PG DB.
ENABLE_CHAT=

# Overpass (OpenStreetMap query) — gated S242. Memory `feedback_no_osm_use_local_geo.md`
# says OSM is build-time only; Android has zero runtime callers. Flip to
# `true` to revive admin-side OSM probing if you need it for build-pipeline
# work; leave blank for V1 retail / runtime safety.
ENABLE_OVERPASS=
