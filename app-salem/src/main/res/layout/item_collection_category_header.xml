  Module: item_collection_category_header.xml

  S268 — Section header row in the CollectionSheet list. Groups POIs by
  category (HISTORICAL_BUILDINGS, WORSHIP, CIVIC, etc.).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="36dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:background="#0E0E12">

    <TextView
        android:id="@+id/headerLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="#E7CDA0"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:textAllCaps="true"
        tools:text="HISTORICAL BUILDINGS" />

    <TextView
        android:id="@+id/headerCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#A89D85"
        android:textSize="11sp"
        tools:text="4 / 32" />

</LinearLayout>
