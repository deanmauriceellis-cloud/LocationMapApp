<?xml version="1.0" encoding="utf-8"?>
<!--
  WickedSalemWitchCityTour — POI Detail Bottom Sheet (Session 113)

  Layout structure (top → bottom):
    - Hero strip (20% of initial screen height, set at runtime — fitXY stretch)
    - Overview row (small POI icon | name / type / address / phone)
    - Visit Website button (visible only if poi.website is populated)
    - Divider
    - Overview / About / The Story sections (from shortNarration / description / longNarration)
    - Divider
    - Things You Can Do section (action buttons synthesized from POI fields)
    - Bottom padding

  Scrollable via the NestedScrollView wrapping everything below the hero.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/poiDetailRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/salemBackground">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/sheet_drag_handle" />

    <!-- Hero strip — height is overridden in PoiDetailSheet.onViewCreated
         to 20% of the initial screen height. -->
    <FrameLayout
        android:id="@+id/heroContainer"
        android:layout_width="match_parent"
        android:layout_height="160dp">

        <ImageView
            android:id="@+id/heroImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:contentDescription="POI hero image" />

        <!-- Visible only when the resolver returns RedPlaceholder. -->
        <TextView
            android:id="@+id/heroOverlayLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="ASSIGN HERO"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:background="#AA000000"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:visibility="gone" />

        <!-- Close X in the top-right corner of the hero strip -->
        <TextView
            android:id="@+id/btnClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:text="\u2715"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="#88000000"
            android:clickable="true"
            android:focusable="true" />
    </FrameLayout>

    <!-- Scrollable body -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:fadingEdge="vertical"
        android:fadingEdgeLength="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="24dp">

            <!-- Overview row: small POI icon | name + type + address + phone -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/overviewIcon"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="12dp"
                    android:scaleType="centerCrop"
                    android:contentDescription="POI thumbnail" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/overviewName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/salemTextPrimary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:maxLines="2"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/overviewType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#AB47BC"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textAllCaps="true"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:id="@+id/overviewAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/salemTextSecondary"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/overviewPhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/salemTextSecondary"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp"
                        android:visibility="gone" />

                    <!-- Stripped-mode only: plain-text URL + hours. Inert text,
                         no click (V1_OFFLINE_ONLY posture; legal posture per
                         PoiContentPolicy for non-licensed commercial POIs). -->
                    <TextView
                        android:id="@+id/overviewWebsite"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/salemTextSecondary"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/overviewHours"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/salemTextSecondary"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp"
                        android:visibility="gone" />
                </LinearLayout>
            </LinearLayout>

            <!-- Visit Website (primary button — only if website field populated) -->
            <TextView
                android:id="@+id/btnWebsite"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/narration_btn_primary_bg"
                android:text="Visit Website"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone" />

            <!-- Divider (hidden in stripped mode) -->
            <View
                android:id="@+id/divider1"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <!-- Short narration (poi.short_narration) -->
            <TextView
                android:id="@+id/labelShort"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Short narration"
                android:textColor="@color/colorAccent"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/bodyShort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/salemTextPrimary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.3" />

            <!-- Description (poi.description) -->
            <TextView
                android:id="@+id/labelAbout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Description"
                android:textColor="@color/colorAccent"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/bodyAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/salemTextPrimary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.3"
                android:visibility="gone" />

            <!-- Long narration (poi.long_narration) -->
            <TextView
                android:id="@+id/labelStory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Long narration"
                android:textColor="@color/colorAccent"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/bodyStory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/salemTextPrimary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.3"
                android:visibility="gone" />

            <!-- S200: Historical narration (poi.historical_narration, strict pre-1860) -->
            <TextView
                android:id="@+id/labelHistorical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Historical narration"
                android:textColor="@color/colorAccent"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/bodyHistorical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/salemTextPrimary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.3"
                android:visibility="gone" />

            <!-- Divider (hidden in stripped mode) -->
            <View
                android:id="@+id/divider2"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <!-- Things You Can Do (hidden in stripped mode) -->
            <TextView
                android:id="@+id/labelActions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Things You Can Do"
                android:textColor="@color/colorAccent"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true" />

            <LinearLayout
                android:id="@+id/actionsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
