  an explicit "X" close button (top-left) and a circular shutter (bottom).
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.camera.view.PreviewView
        android:id="@+id/reconPreview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/reconCloseBtn"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:padding="14dp"
        android:src="@drawable/ic_recon_close"
        android:background="@drawable/recon_chip_bg"
        android:scaleType="fitCenter"
        android:contentDescription="Close camera"
        android:tooltipText="Close"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/reconHud"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginStart="80dp"
        android:layout_marginEnd="16dp"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:singleLine="false"
        android:maxLines="2"
        android:ellipsize="end"
        android:shadowColor="#CC000000"
        android:shadowRadius="3"
        android:shadowDx="0"
        android:shadowDy="1"
        android:text=""
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/reconCloseBtn"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/reconShutterBtn"
        android:layout_width="84dp"
        android:layout_height="84dp"
        android:layout_marginBottom="40dp"
        android:src="@drawable/recon_shutter_button"
        android:scaleType="fitCenter"
        android:contentDescription="Capture photo"
        android:tooltipText="Capture"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
