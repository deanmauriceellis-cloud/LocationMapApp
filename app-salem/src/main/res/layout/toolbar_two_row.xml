<!-- Slim toolbar: icon row (40dp) + status line (24dp) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/toolbarTwoRowRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- S168 Icon row:
         Home | Weather | spacer | TileSource | Alerts | Grid | About | Speaker
         Speaker tap = cancel current narration if speaking, else replay last.
         Speaker long-press = audio content popup (Oracle/Meaningful/Ambient/
         Businesses mute + detail radio). -->
    <LinearLayout
        android:id="@+id/toolbarIconRow"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <ImageView
            android:id="@+id/toolbarHomeIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_home"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Home"
            android:tooltipText="Home" />

        <ImageView
            android:id="@+id/toolbarCameraIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_camera_recon"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Take recon photo (GPS+compass EXIF)"
            android:tooltipText="Camera (GPS+compass EXIF)" />

        <!-- S228 — GPS-burst camera. Visible only when BuildDefaults.GPS_BURST_ENABLED
             (debug builds). Toggle ON = auto-shoot every 3s on each new fix; OFF = idle. -->
        <ImageView
            android:id="@+id/toolbarGpsBurstIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_camera_recon"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            android:contentDescription="GPS-burst camera (auto-shoot every 3s while ON)"
            android:tooltipText="GPS-burst camera (toggle)" />

        <!-- S229 — field-edit mode. Visible only when BuildDefaults.FIELD_EDIT_ENABLED
             (debug builds). Toggle ON = long-press a POI marker to capture a field edit. -->
        <FrameLayout
            android:id="@+id/toolbarFieldEditWrap"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:visibility="gone">
            <ImageView
                android:id="@+id/toolbarFieldEditIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_about"
                android:scaleType="centerInside"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Field-edit mode (long-press POIs to capture edits)"
                android:tooltipText="Field-edit mode (toggle)" />
            <TextView
                android:id="@+id/fieldEditBadge"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="top|end"
                android:gravity="center"
                android:textSize="9sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/badge_red"
                android:visibility="gone" />
        </FrameLayout>

        <!-- S249 — SuperAdmin mode toggle. Visible only when
             BuildDefaults.SUPER_ADMIN_ENABLED (debug builds). Tap toggles the
             runtime override (`SuperAdminMode.allowNetwork`) that bypasses
             V1_OFFLINE_ONLY for the parked external services
             (weather / MBTA / aircraft / METAR / webcams / radar). -->
        <FrameLayout
            android:id="@+id/toolbarSuperAdminWrap"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:visibility="gone">
            <ImageView
                android:id="@+id/toolbarSuperAdminIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_debug"
                android:scaleType="centerInside"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="SuperAdmin mode (toggle parked V1+ services)"
                android:tooltipText="SuperAdmin mode (toggle)" />
        </FrameLayout>

        <ImageView
            android:id="@+id/toolbarWeatherIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_wx_default"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Weather"
            android:tooltipText="Weather" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/toolbarTileSourceIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_map_layers"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="8dp"
            android:contentDescription="Map Layers"
            android:tooltipText="Map Layers" />

        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp">
            <ImageView
                android:id="@+id/toolbarAlertsIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_alerts"
                android:scaleType="centerInside"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Alerts"
                android:tooltipText="Alerts" />
            <TextView
                android:id="@+id/alertsBadge"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="top|end"
                android:gravity="center"
                android:textSize="9sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/badge_red"
                android:visibility="gone" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp">
            <ImageView
                android:id="@+id/toolbarGridButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_grid_menu"
                android:scaleType="centerInside"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Menu"
                android:tooltipText="Menu" />
            <TextView
                android:id="@+id/layersBadge"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="top|end"
                android:gravity="center"
                android:textSize="9sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/badge_teal"
                android:visibility="gone" />
        </FrameLayout>

        <ImageView
            android:id="@+id/toolbarAboutIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_about"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="8dp"
            android:contentDescription="About"
            android:tooltipText="About" />

        <!-- S268 — POI Passport. Opens PassportSheet (per-user "heard" list). -->
        <ImageView
            android:id="@+id/toolbarPassportIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_passport_witch_hat"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="8dp"
            android:contentDescription="Passport — POIs you've heard"
            android:tooltipText="Passport" />

        <!-- S168 — single speaker button: tap = cancel/replay, long-press = audio popup -->
        <ImageView
            android:id="@+id/toolbarAudioIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_audio_control"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="8dp"
            android:contentDescription="Cancel or replay narration (long-press: audio settings)"
            android:tooltipText="Cancel/replay (long-press: audio settings)" />

    </LinearLayout>

    <!-- Status line: persistent single-line info bar -->
    <TextView
        android:id="@+id/toolbarStatusLine"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:gravity="center_vertical"
        android:textSize="11sp"
        android:textColor="#B0FFFFFF"
        android:singleLine="true"
        android:ellipsize="end"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="#20000000" />

</LinearLayout>
