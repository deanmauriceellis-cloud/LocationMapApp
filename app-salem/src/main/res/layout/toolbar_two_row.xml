<!-- Slim toolbar: icon row (40dp) + status line (24dp) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/toolbarTwoRowRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- S145 Must-Have #45 — Icon row:
         nav cluster (First / Prev / Next+Pause / Jump) | Weather | Home | spacer |
         TileSource | Alerts | Grid | Audio | About -->
    <LinearLayout
        android:id="@+id/toolbarIconRow"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <!-- ── S145 nav cluster: First / Prev / Next+Pause / Jump ── -->
        <ImageView
            android:id="@+id/toolbarNavFirst"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_nav_first"
            android:scaleType="centerInside"
            android:padding="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="First narration"
            android:tooltipText="First narration" />

        <ImageView
            android:id="@+id/toolbarNavPrev"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_nav_prev"
            android:scaleType="centerInside"
            android:padding="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Previous narration"
            android:tooltipText="Previous narration" />

        <ImageView
            android:id="@+id/toolbarNavNext"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_nav_next"
            android:scaleType="centerInside"
            android:padding="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Next narration (long-press to pause)"
            android:tooltipText="Next (long-press to pause)" />

        <ImageView
            android:id="@+id/toolbarNavJump"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_nav_jump"
            android:scaleType="centerInside"
            android:padding="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Open what's playing"
            android:tooltipText="Open what's playing" />

        <ImageView
            android:id="@+id/toolbarWeatherIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_wx_default"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Weather"
            android:tooltipText="Weather" />

        <ImageView
            android:id="@+id/toolbarHomeIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_home"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="8dp"
            android:contentDescription="Home"
            android:tooltipText="Home" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/toolbarTileSourceIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_map_layers"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="8dp"
            android:contentDescription="Map Layers"
            android:tooltipText="Map Layers" />

        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp">
            <ImageView
                android:id="@+id/toolbarAlertsIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_alerts"
                android:scaleType="centerInside"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Alerts"
                android:tooltipText="Alerts" />
            <TextView
                android:id="@+id/alertsBadge"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="top|end"
                android:gravity="center"
                android:textSize="9sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/badge_red"
                android:visibility="gone" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp">
            <ImageView
                android:id="@+id/toolbarGridButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_grid_menu"
                android:scaleType="centerInside"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Menu"
                android:tooltipText="Menu" />
            <TextView
                android:id="@+id/layersBadge"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="top|end"
                android:gravity="center"
                android:textSize="9sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/badge_teal"
                android:visibility="gone" />
        </FrameLayout>

        <!-- S145 #45 — universal audio control (tap = popup, long-press = detail cycle) -->
        <ImageView
            android:id="@+id/toolbarAudioIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_audio_control"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="8dp"
            android:contentDescription="Audio controls"
            android:tooltipText="Audio (long-press: detail level)" />

        <ImageView
            android:id="@+id/toolbarAboutIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_about"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="8dp"
            android:contentDescription="About"
            android:tooltipText="About" />

    </LinearLayout>

    <!-- Status line: persistent single-line info bar -->
    <TextView
        android:id="@+id/toolbarStatusLine"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:gravity="center_vertical"
        android:textSize="11sp"
        android:textColor="#B0FFFFFF"
        android:singleLine="true"
        android:ellipsize="end"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="#20000000" />

</LinearLayout>
