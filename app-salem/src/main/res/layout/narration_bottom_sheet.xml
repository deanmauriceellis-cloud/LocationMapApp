<?xml version="1.0" encoding="utf-8"?>
<!--
  WickedSalemWitchCityTour — Narration Bottom Sheet
  Slides up when a narration point triggers (geofence or dock tap).
  Top: POI image | Middle: title + narration text | Bottom: action buttons
  Phase 9T: Salem Walking Tour Restructure
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/narrationSheet"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/narration_sheet_bg"
    android:elevation="16dp"
    android:clickable="true"
    android:focusable="true"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:background="@drawable/sheet_drag_handle" />

    <!-- Top: POI image (1/3 of sheet, hidden if no image) -->
    <ImageView
        android:id="@+id/narrationImage"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true"
        android:contentDescription="POI image"
        android:visibility="gone" />

    <!-- Category badge + title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:gravity="center_vertical">

        <!-- Category color dot -->
        <View
            android:id="@+id/categoryDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/dock_icon_ring" />

        <!-- Category label -->
        <TextView
            android:id="@+id/categoryLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#AB47BC"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginEnd="12dp" />

        <!-- Distance -->
        <TextView
            android:id="@+id/distanceLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Title -->
    <TextView
        android:id="@+id/narrationTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Scrollable narration text -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:maxHeight="200dp"
        android:fadingEdge="vertical"
        android:fadingEdgeLength="16dp">

        <TextView
            android:id="@+id/narrationText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#CCCCCC"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.3" />

    </ScrollView>

    <!-- ── Subtopics block (S220) ───────────────────────────────────────
         Same chip strip + collapsible body card pattern as the POI
         Detail Sheet. Hidden when narration_subtopics is empty/missing,
         and explicitly hidden by showNewspaperSheet() for headline mode. -->
    <View
        android:id="@+id/subtopicDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="#33AB47BC"
        android:visibility="gone" />

    <TextView
        android:id="@+id/labelSubtopics"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginStart="16dp"
        android:text="Explore subtopics"
        android:textColor="#AB47BC"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <HorizontalScrollView
        android:id="@+id/subtopicChipScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:scrollbars="none"
        android:fadingEdge="horizontal"
        android:fadingEdgeLength="20dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/subtopicChipRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/subtopicBodyStack"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:orientation="vertical"
        android:visibility="gone" />

    <!-- Queue indicator -->
    <TextView
        android:id="@+id/queueIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="4dp"
        android:textColor="#666666"
        android:textSize="10sp"
        android:visibility="gone" />

    <!-- Action buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:gravity="center">

        <!-- Skip -->
        <TextView
            android:id="@+id/btnSkip"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/narration_btn_bg"
            android:text="Skip"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />

        <!-- Play/Pause TTS -->
        <TextView
            android:id="@+id/btnPlayPause"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/narration_btn_primary_bg"
            android:text="▶ Listen"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />

        <!-- More Info -->
        <TextView
            android:id="@+id/btnMoreInfo"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/narration_btn_bg"
            android:text="More"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />

        <!-- Directions -->
        <TextView
            android:id="@+id/btnDirections"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/narration_btn_bg"
            android:text="Walk"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />

        <!-- Show Geofence -->
        <TextView
            android:id="@+id/btnGeofence"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="@drawable/narration_btn_bg"
            android:text="Fence"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</LinearLayout>
