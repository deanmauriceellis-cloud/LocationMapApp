<?xml version="1.0" encoding="utf-8"?>
<!--
  WickedSalemWitchCityTour — Narration Bottom Sheet
  Slides up when a narration point triggers (geofence or dock tap).
  Top: drag handle | Middle: scrollable wrapper (image/title/text/subtopics)
  Bottom: action buttons (always visible — anchored to bottom of cap)
  S265: middle wrapped in outer ScrollView so the 20%-cap (set at runtime)
  never hides the button row.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/narrationSheet"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/narration_sheet_bg"
    android:elevation="16dp"
    android:clickable="true"
    android:focusable="true"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:background="@drawable/sheet_drag_handle" />

    <!-- S265: outer scroll wrapper — fills the space between drag handle and
         button row. With root height capped at 20% screen, this is what
         scrolls; the button row below stays anchored. -->
    <ScrollView
        android:id="@+id/narrationScrollWrapper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fadingEdge="vertical"
        android:fadingEdgeLength="16dp"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top: POI image (hidden if no image) -->
            <ImageView
                android:id="@+id/narrationImage"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginTop="8dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                android:contentDescription="POI image"
                android:visibility="gone" />

            <!-- Category badge + title -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/categoryDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/dock_icon_ring" />

                <TextView
                    android:id="@+id/categoryLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#AB47BC"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/distanceLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#888888"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Title -->
            <TextView
                android:id="@+id/narrationTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Narration body text — plain TextView now; outer ScrollView handles scrolling -->
            <TextView
                android:id="@+id/narrationText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.3" />

            <!-- ── Subtopics block (S220) -->
            <View
                android:id="@+id/subtopicDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="10dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="#33AB47BC"
                android:visibility="gone" />

            <TextView
                android:id="@+id/labelSubtopics"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="16dp"
                android:text="Explore subtopics"
                android:textColor="#AB47BC"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <HorizontalScrollView
                android:id="@+id/subtopicChipScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:scrollbars="none"
                android:fadingEdge="horizontal"
                android:fadingEdgeLength="20dp"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/subtopicChipRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/subtopicBodyStack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:orientation="vertical"
                android:visibility="gone" />

            <!-- Queue indicator -->
            <TextView
                android:id="@+id/queueIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="4dp"
                android:textColor="#666666"
                android:textSize="10sp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <!-- Action buttons row — always visible (anchored to bottom of 20% cap) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:gravity="center">

        <TextView
            android:id="@+id/btnSkip"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/narration_btn_bg"
            android:text="Skip"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnPlayPause"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/narration_btn_primary_bg"
            android:text="▶ Listen"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnMoreInfo"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/narration_btn_bg"
            android:text="More"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnDirections"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/narration_btn_bg"
            android:text="Walk"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnGeofence"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/narration_btn_bg"
            android:text="Fence"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />

        <!-- Dismiss (S265) — hide banner without stopping narration -->
        <TextView
            android:id="@+id/btnDismiss"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="@drawable/narration_btn_bg"
            android:text="✕"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Dismiss banner" />

    </LinearLayout>

</LinearLayout>
