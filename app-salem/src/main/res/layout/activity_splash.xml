<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_background">

    <!-- Centered Lottie animation -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/splashAnimation"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center"
        android:layout_marginBottom="60dp"
        app:lottie_rawRes="@raw/witchkitty_splash"
        app:lottie_autoPlay="true"
        app:lottie_loop="false" />

    <!-- App title text — fades in after animation starts -->
    <LinearLayout
        android:id="@+id/splashTextContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|bottom"
        android:layout_marginBottom="160dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:alpha="0">

        <TextView
            android:id="@+id/splashTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wicked Salem"
            android:textColor="@color/colorAccent"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="serif" />

        <TextView
            android:id="@+id/splashSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Witch City Tour"
            android:textColor="@color/salemTextPrimary"
            android:textSize="18sp"
            android:fontFamily="serif"
            android:layout_marginTop="4dp" />

    </LinearLayout>

</FrameLayout>
