<?xml version="1.0" encoding="utf-8"?>
<!--
  S221 — Persistent floating banner shown while a tour-detour is active.
  Pinned to the top of the map; one-tap opens the detour-management dialog
  (Return to tour / Stop tour, continue later / Cancel).
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/detourBannerWrapper"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="top|center_horizontal"
    android:layout_marginTop="96dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:visibility="gone">

    <TextView
        android:id="@+id/detourBannerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/detour_banner_bg"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:elevation="6dp"
        android:clickable="true"
        android:focusable="true"
        android:text="On detour · tap to manage" />
</FrameLayout>
