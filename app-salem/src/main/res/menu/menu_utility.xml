<!-- menu/menu_utility.xml -->
<menu xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- S242: record_gps + email_gpx menu items removed. Both were
         stub-only (no implementation). Build Story / Analyze Today /
         Travel Anomalies stubs kept — they're parked V1+ features. -->

    <!-- Button: launch story-builder website with stored coordinates -->
    <item
        android:id="@+id/menu_util_build_story"
        android:title="Build Travel Story…"
        app:showAsAction="never" />

    <!-- Button: launch analysis website for today's travels -->
    <item
        android:id="@+id/menu_util_analyze_today"
        android:title="Analyze Today's Travels…"
        app:showAsAction="never" />

    <!-- Button: detect anomalies in recorded movements -->
    <item
        android:id="@+id/menu_util_anomalies"
        android:title="Show Travel Anomalies…"
        app:showAsAction="never" />

    <item android:id="@+id/menu_util_divider" style="@style/Widget.AppCompat.ActionBar.TabBar"/>

    <!-- Populate POIs: systematic grid scanner (not checkable — title changes to show state) -->
    <item
        android:id="@+id/menu_util_populate_pois"
        android:title="Populate POIs"
        app:showAsAction="never" />

    <!-- 10km Probe: single wide search at map center to discover POIs in low-density areas -->
    <item
        android:id="@+id/menu_util_probe_10km"
        android:title="10km Probe Populate"
        app:showAsAction="never" />

    <!-- Fill Probe: use existing radius hints to fill gaps (stub for now) -->
    <item
        android:id="@+id/menu_util_fill_probe"
        android:title="Fill Probe Populate"
        app:showAsAction="never" />

    <!-- Debug log viewer (existing feature surfaced here) -->
    <item
        android:id="@+id/menu_util_debug_log"
        android:title="Debug Log Viewer"
        app:showAsAction="never" />

    <!-- S243: dump every map overlay's state to DebugLogger / TCP stream.
         Operator-driven, used when a visual glitch needs remote diagnosis. -->
    <item
        android:id="@+id/menu_util_debug_dump_map"
        android:title="Dump Map Overlays (Debug)"
        app:showAsAction="never" />

    <!-- S243: jump straight into the Android TTS settings screen.
         Bluestacks's stripped system UI doesn't surface Accessibility/TTS,
         so we fire the Intent directly. -->
    <item
        android:id="@+id/menu_util_debug_open_tts"
        android:title="Open TTS Settings (Debug)"
        app:showAsAction="never" />

    <!-- GPS mode toggle (existing feature) -->
    <item
        android:id="@+id/menu_util_gps_mode"
        android:title="GPS / Manual Location Mode"
        android:checkable="true"
        app:showAsAction="never" />

    <!-- S149: override the Salem bbox clamp (use real GPS even outside Salem) -->
    <item
        android:id="@+id/menu_util_gps_bbox_override"
        android:title="Use Real GPS Outside Salem"
        android:checkable="true"
        app:showAsAction="never" />

    <!-- Silent POI fill debug banner (checkable — shows banner when background fill is running) -->
    <item
        android:id="@+id/menu_util_silent_fill_debug"
        android:title="Silent Fill Debug Banner"
        android:checkable="true"
        app:showAsAction="never" />

    <!-- Map legend dialog -->
    <item
        android:id="@+id/menu_util_legend"
        android:title="Map Legend"
        app:showAsAction="never" />

    <!-- Phase 9X: Witch Trials narrator mode (auto-speak detail screen body) -->
    <item
        android:id="@+id/menu_util_narrator_mode"
        android:title="Narrator Mode (auto-speak)"
        android:checkable="true"
        app:showAsAction="never" />

</menu>
