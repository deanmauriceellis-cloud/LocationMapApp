<!--
  S219 — Subtopic chip background (inactive). Rounded pill, faint translucent
  fuchsia border on top of the night-blue sheet so chips read as tappable.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#FFC026D3" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#FFE879F9" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#66C026D3" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#FFC026D3" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#33C026D3" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#88C026D3" />
        </shape>
    </item>
</selector>
