<!--
  S219 — Subtopic body card background. Slightly lighter than the sheet,
  rounded corners, subtle border so cards read as discrete units in the stack.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#221A1340" />
    <corners android:radius="10dp" />
    <stroke android:width="1dp" android:color="#33C026D3" />
</shape>
