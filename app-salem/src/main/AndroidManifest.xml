<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Location (only outside contact V1 makes — GPS satellite) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- S180: V1 zero-network rule — INTERNET, ACCESS_NETWORK_STATE
         permissions REMOVED. The OS denies any net access at the syscall
         layer regardless of code. Re-add for V2 alongside FeatureFlags
         flip. See feedback_v1_no_external_contact.md. -->

    <!-- OSMDroid tile cache write (legacy bundled tile extraction) -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Email GPX export -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- S125: Keep CPU running during walk-sim when the screen locks.
         Without this, overnight walks stall intermittently because the
         tablet deep-sleeps and our coroutine delays fall behind the
         simulated GPS timestamps. PARTIAL — screen may still turn off. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".WickedSalemApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WickedSalem">

        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.WickedSalem.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.SalemMainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode|smallestScreenSize|density"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.DebugLogActivity"
            android:exported="false"
            android:label="Debug Log" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- S180: VoiceTestActivity narrowed from exported=true to exported=false.
             Internal-only debug activity; nothing outside this APK should be
             able to launch it. Should be moved to app-salem/src/debug/ for V2. -->
        <activity
            android:name=".debug.VoiceTestActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.NoActionBar" />

        <!-- S171/S180: custom 2D map prototype kept reachable via the
             in-app FAB only. LAUNCHER intent-filter REMOVED for V1 so the
             prototype does not appear as a separate app icon. Activity
             stays so the FAB launch path keeps working. -->
        <activity
            android:name=".wickedmap.WickedMapPrototypeActivity"
            android:exported="false"
            android:label="WickedMap Proto"
            android:theme="@style/Theme.AppCompat.NoActionBar" />

    </application>

</manifest>
