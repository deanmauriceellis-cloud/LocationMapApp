<!-- Slim toolbar: icon row (40dp) + status line (24dp) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/toolbarTwoRowRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Icon row: Weather | Home | spacer | DarkMode | Alerts | Grid | About -->
    <LinearLayout
        android:id="@+id/toolbarIconRow"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <ImageView
            android:id="@+id/toolbarWeatherIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_wx_default"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Weather"
            android:tooltipText="Weather" />

        <ImageView
            android:id="@+id/toolbarHomeIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_home"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="8dp"
            android:contentDescription="Home"
            android:tooltipText="Home" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/toolbarDarkModeIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_dark_mode"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="8dp"
            android:contentDescription="Dark Mode"
            android:tooltipText="Dark Mode" />

        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp">
            <ImageView
                android:id="@+id/toolbarAlertsIcon"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_alerts"
                android:scaleType="centerInside"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Alerts"
                android:tooltipText="Alerts" />
            <TextView
                android:id="@+id/alertsBadge"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="top|end"
                android:gravity="center"
                android:textSize="9sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/badge_red"
                android:visibility="gone" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp">
            <ImageView
                android:id="@+id/toolbarGridButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_grid_menu"
                android:scaleType="centerInside"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Menu"
                android:tooltipText="Menu" />
            <TextView
                android:id="@+id/layersBadge"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="top|end"
                android:gravity="center"
                android:textSize="9sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/badge_teal"
                android:visibility="gone" />
        </FrameLayout>

        <ImageView
            android:id="@+id/toolbarAboutIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_about"
            android:scaleType="centerInside"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="8dp"
            android:contentDescription="About"
            android:tooltipText="About" />

    </LinearLayout>

    <!-- Status line: persistent single-line info bar -->
    <TextView
        android:id="@+id/toolbarStatusLine"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:gravity="center_vertical"
        android:textSize="11sp"
        android:textColor="#B0FFFFFF"
        android:singleLine="true"
        android:ellipsize="end"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="#20000000" />

</LinearLayout>
