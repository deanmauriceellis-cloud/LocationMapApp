[624|7428] 19:03:17.380 I/NARR-STATE: narrationState → Speaking(segment=NarrationSegment(id=sheet_historic_salem_inc__1530413016615371, text=Founded in 1944, Historic Salem, Inc. is a non-profit organization dedicated to the architectural preservation and protection of Salem, Massachusetts. They are best known as the publisher of 'The Salem Handbook', a valuable resource for homeowners and those interested in Salem’s historic dwellings. In 1983, Historic Salem collaborated with the Essex Institute to publish 'Architecture in Salem' by Bryant Franklin Tolles, further cementing their commitment to documenting and safeguarding the city’s built environment., type=HINT, poiName=Historic Salem, Inc., voiceId=null, kind=POI, category=null, refId=sheet_historic_salem_inc_, isReplay=false)) (autoPlay=true, queueSize=1)
